generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  operator
  warehouse
}

enum UserStatus {
  active
  disabled
}

enum OrderStatus {
  draft
  pending_shipment
  shipped
  completed
  cancelled
}

enum UploadBizType {
  order_product_image
}

model User {
  id            Int              @id @default(autoincrement())
  username      String           @unique @db.VarChar(50)
  passwordHash  String           @map("password_hash") @db.VarChar(255)
  displayName   String           @map("display_name") @db.VarChar(50)
  mobile        String?          @db.VarChar(20)
  role          UserRole
  status        UserStatus       @default(active)
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")
  createdOrders Order[]          @relation("CreatedOrders")
  uploadedFiles UploadFile[]
  orderLogs     OrderStatusLog[]

  @@map("users")
}

model Customer {
  id               Int       @id @default(autoincrement())
  name             String    @db.VarChar(50)
  mobile           String    @unique @db.VarChar(20)
  wechatNickname   String?   @map("wechat_nickname") @db.VarChar(100)
  receiverName     String?   @map("receiver_name") @db.VarChar(50)
  receiverMobile   String?   @map("receiver_mobile") @db.VarChar(20)
  receiverProvince String?   @map("receiver_province") @db.VarChar(50)
  receiverCity     String?   @map("receiver_city") @db.VarChar(50)
  receiverDistrict String?   @map("receiver_district") @db.VarChar(50)
  receiverAddress  String?   @map("receiver_address") @db.VarChar(255)
  note             String?   @db.VarChar(500)
  lastOrderAt      DateTime? @map("last_order_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  orders           Order[]

  @@map("customers")
}

model OrderSequence {
  bizDate      DateTime @id @map("biz_date") @db.Date
  currentValue Int      @default(0) @map("current_value")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("order_sequences")
}

model Order {
  id               Int              @id @default(autoincrement())
  orderNo          String           @unique @map("order_no") @db.VarChar(20)
  customerId       Int              @map("customer_id")
  status           OrderStatus      @default(pending_shipment)
  clientTokenHash  String           @map("client_token_hash") @db.VarChar(64)
  clientLinkPath   String           @map("client_link_path") @db.VarChar(255)
  createdById      Int              @map("created_by_id")
  receiverName     String           @map("receiver_name") @db.VarChar(50)
  receiverMobile   String           @map("receiver_mobile") @db.VarChar(20)
  receiverProvince String?          @map("receiver_province") @db.VarChar(50)
  receiverCity     String?          @map("receiver_city") @db.VarChar(50)
  receiverDistrict String?          @map("receiver_district") @db.VarChar(50)
  receiverAddress  String           @map("receiver_address") @db.VarChar(255)
  totalAmount      Decimal          @map("total_amount") @db.Decimal(10, 2)
  shippingFee      Decimal          @default(0) @map("shipping_fee") @db.Decimal(10, 2)
  discountAmount   Decimal          @default(0) @map("discount_amount") @db.Decimal(10, 2)
  payableAmount    Decimal          @map("payable_amount") @db.Decimal(10, 2)
  operatorRemark   String?          @map("operator_remark") @db.VarChar(1000)
  warehouseRemark  String?          @map("warehouse_remark") @db.VarChar(1000)
  courierCompany   String?          @map("courier_company") @db.VarChar(50)
  trackingNo       String?          @map("tracking_no") @db.VarChar(50)
  shippedAt        DateTime?        @map("shipped_at")
  completedAt      DateTime?        @map("completed_at")
  cancelledAt      DateTime?        @map("cancelled_at")
  cancelledReason  String?          @map("cancelled_reason") @db.VarChar(255)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  customer         Customer         @relation(fields: [customerId], references: [id])
  createdBy        User             @relation("CreatedOrders", fields: [createdById], references: [id])
  items            OrderItem[]
  images           UploadFile[]
  logs             OrderStatusLog[]

  @@index([customerId], map: "idx_orders_customer_id")
  @@index([status, createdAt], map: "idx_orders_status_created_at")
  @@index([receiverMobile], map: "idx_orders_receiver_mobile")
  @@map("orders")
}

model OrderItem {
  id          Int          @id @default(autoincrement())
  orderId     Int          @map("order_id")
  productName String       @map("product_name") @db.VarChar(100)
  productSpec String?      @map("product_spec") @db.VarChar(255)
  quantity    Int          @default(1)
  unitPrice   Decimal      @map("unit_price") @db.Decimal(10, 2)
  lineAmount  Decimal      @map("line_amount") @db.Decimal(10, 2)
  remark      String?      @db.VarChar(255)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  order       Order        @relation(fields: [orderId], references: [id])
  images      UploadFile[]

  @@index([orderId], map: "idx_order_items_order_id")
  @@map("order_items")
}

model UploadFile {
  id            Int           @id @default(autoincrement())
  orderId       Int?          @map("order_id")
  orderItemId   Int?          @map("order_item_id")
  uploaderId    Int           @map("uploader_id")
  bizType       UploadBizType @map("biz_type")
  storageDriver String        @map("storage_driver") @db.VarChar(32)
  storageKey    String?       @map("storage_key") @db.VarChar(500)
  originalName  String        @map("original_name") @db.VarChar(255)
  fileName      String        @map("file_name") @db.VarChar(255)
  mimeType      String        @map("mime_type") @db.VarChar(100)
  fileSize      Int           @map("file_size")
  fileUrl       String        @map("file_url") @db.VarChar(500)
  expiresAt     DateTime      @map("expires_at")
  deletedAt     DateTime?     @map("deleted_at")
  createdAt     DateTime      @default(now()) @map("created_at")
  order         Order?        @relation(fields: [orderId], references: [id])
  orderItem     OrderItem?    @relation(fields: [orderItemId], references: [id])
  uploader      User          @relation(fields: [uploaderId], references: [id])

  @@index([orderId], map: "idx_upload_files_order_id")
  @@index([orderItemId], map: "idx_upload_files_order_item_id")
  @@index([expiresAt], map: "idx_upload_files_expires_at")
  @@map("upload_files")
}

model OrderStatusLog {
  id         Int          @id @default(autoincrement())
  orderId    Int          @map("order_id")
  fromStatus OrderStatus? @map("from_status")
  toStatus   OrderStatus  @map("to_status")
  action     String       @db.VarChar(32)
  operatorId Int?         @map("operator_id")
  note       String?      @db.VarChar(255)
  createdAt  DateTime     @default(now()) @map("created_at")
  order      Order        @relation(fields: [orderId], references: [id])
  operator   User?        @relation(fields: [operatorId], references: [id])

  @@index([orderId], map: "idx_order_status_logs_order_id")
  @@map("order_status_logs")
}
